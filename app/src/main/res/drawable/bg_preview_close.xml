<?xml version="1.0" encoding="utf-8"?>
<!-- Dark circular button with a white halo ring so it stays visible on black pages. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="oval">
            <solid android:color="#FFFFFF" />
        </shape>
    </item>
    <item
        android:left="3dp"
        android:top="3dp"
        android:right="3dp"
        android:bottom="3dp">
        <shape android:shape="oval">
            <solid android:color="#CC000000" />
        </shape>
    </item>
</layer-list>
