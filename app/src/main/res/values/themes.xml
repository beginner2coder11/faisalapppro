<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Web2App" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/colorAccent</item>
        <item name="android:colorBackground">@color/appBackground</item>
        <item name="colorSurface">@color/surface</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Rounded, modern dialogs -->
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.Web2App.Dialog</item>
        <item name="textInputStyle">@style/Widget.Web2App.TextInput</item>
    </style>

    <!-- Cropper: needs a visible action bar to host the "Done" menu action
         (the app theme is NoActionBar, which hides it). Dark action bar = light icons. -->
    <style name="Theme.Web2App.Cropper" parent="Theme.Material3.DayNight">
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/colorPrimaryDark</item>
    </style>

    <!-- Bottom-nav tab label: light weight (default Material3 label is medium) -->
    <style name="TextAppearance.Web2App.Tab" parent="TextAppearance.Material3.LabelMedium">
        <item name="android:textStyle">normal</item>
        <item name="android:fontFamily">sans-serif-light</item>
        <item name="fontFamily">sans-serif-light</item>
        <item name="android:textFontWeight">300</item>
    </style>

    <!-- Custom dialog pop/fade animation -->
    <style name="DialogAnimation">
        <item name="android:windowEnterAnimation">@anim/dialog_in</item>
        <item name="android:windowExitAnimation">@anim/dialog_out</item>
    </style>

    <!-- Dialog button styles -->
    <style name="Widget.Web2App.DialogButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.Web2App.DialogButton.Tonal" parent="Widget.Material3.Button.TonalButton">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">13dp</item>
        <item name="android:paddingBottom">13dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/appBackground</item>
        <item name="android:textColor">@color/textSecondary</item>
    </style>

    <!-- Outlined, rounded text fields -->
    <style name="Widget.Web2App.TextInput" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">14dp</item>
        <item name="boxCornerRadiusTopEnd">14dp</item>
        <item name="boxCornerRadiusBottomStart">14dp</item>
        <item name="boxCornerRadiusBottomEnd">14dp</item>
        <item name="hintTextColor">@color/colorPrimary</item>
        <item name="boxStrokeColor">@color/colorPrimary</item>
    </style>

    <!-- Rounded dialog with branded buttons -->
    <style name="ThemeOverlay.Web2App.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Web2App.Dialog</item>
        <item name="colorPrimary">@color/colorPrimary</item>
    </style>

    <style name="ShapeAppearance.Web2App.Dialog" parent="">
        <item name="cornerFamily">rounded</item>
        <item name="cornerSize">24dp</item>
    </style>

    <!-- Filled primary button, pill-ish -->
    <style name="Widget.Web2App.Button" parent="Widget.Material3.Button">
        <item name="cornerRadius">14dp</item>
        <item name="android:paddingTop">14dp</item>
        <item name="android:paddingBottom">14dp</item>
        <item name="android:textSize">15sp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:letterSpacing">0.01</item>
    </style>

    <!-- Text button for secondary actions -->
    <style name="Widget.Web2App.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">14sp</item>
    </style>
</resources>
